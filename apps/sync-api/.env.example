APP_ENV=development
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000
CORS_ORIGIN=*
LOG_LEVEL=info

POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/obsidian_sync
JWT_SECRET=change-me-at-least-16-characters
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL_DAYS=30
SYNC_PREPARE_TTL_SECONDS=600
TOMBSTONE_RETENTION_DAYS=30

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=obsidian-sync
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123456
# Set this to protect /auth/bootstrap-admin outside local development.
# BOOTSTRAP_ADMIN_TOKEN=replace-with-a-random-bootstrap-token
